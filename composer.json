{
    "name": "olegbacalu/verdikt",
    "description": "Verdikt — classifies German customer replies (delivery scheduling): deterministic rules cascade vs LLM via Anthropic API, with an eval page comparing both engines.",
    "type": "project",
    "license": "MIT",
    "keywords": ["php", "slim", "anthropic", "llm", "classifier"],
    "require": {
        "php": "^8.3",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.9",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "symfony/polyfill-intl-normalizer": "^1.31",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Verdikt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Verdikt\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "serve": "php -S localhost:8080 -t public"
    },
    "config": {
        "sort-packages": true
    }
}
